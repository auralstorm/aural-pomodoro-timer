{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "aural-pomodoro-timer",
  "version": "0.1.0",
  "identifier": "com.hai.aural-pomodoro-timer",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "番茄时钟",
        "width": 1600,
        "height": 900,
        "minWidth": 1600,
        "minHeight": 900,
        "decorations": false,
        "transparent": false,
        "backgroundColor": "#F2DAD2",
        "focus": true
      }
    ],
    "security": {
      "csp": "default-src 'self' 'unsafe-inline' data:; img-src 'self' data: https://*; script-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net; style-src 'self' 'unsafe-inline'; connect-src https://*; worker-src blob:; child-src blob:;"
    }
  },
  "plugins": {
    "http": {
      "allowlist": {
        "all": true,
        "request": {
          "all": true,
          "scope": [
            "https://**"
          ]
        }
      }
    },
    "window": {
      "allowlist": {
        "all": true
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis",
      "deb",
      "appimage",
      "dmg"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
